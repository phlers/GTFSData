<Window x:Class="GTFSData.HaltestellenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gmap="clr-namespace:GMap.NET.WindowsPresentation;assembly=GMap.NET.WindowsPresentation"
        Icon="logon.ico"
        Title="Modul: Stop Viewer Pro" Height="750" Width="1300" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Background="#121212">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#121212" CornerRadius="4">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555" CornerRadius="4" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="SmoothTextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TitleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="CloseButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Margin="0,2,5,2" Padding="12,10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252526"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0078D7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#181818" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <TextBlock Text="GTFS Viewer Pro - Stop Viewer" Foreground="#888" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Style="{StaticResource TitleBarButton}" Click="BtnMinimize_Click"/>
                <Button Content="☐" Style="{StaticResource TitleBarButton}" Click="BtnMaximize_Click"/>
                <Button Content="✕" Style="{StaticResource CloseButton}" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#181818" BorderBrush="#222" BorderThickness="0,1,1,0" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="150"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🚏 Haltestellen &amp; Details" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                    <TextBox x:Name="TxtSearch" Grid.Row="1" Style="{StaticResource SmoothTextBox}" Margin="0,0,0,10" TextChanged="TxtSearch_TextChanged" />

                    <ListBox x:Name="ListStops" Grid.Row="2" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="ListStops_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayStopName}" FontWeight="Bold" FontSize="14" Foreground="White" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding stop_desc}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="4" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,15,0,0" BorderBrush="#333" BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Stations-Informationen" Foreground="#0078D7" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                <TextBlock x:Name="TxtName" Text="Bitte wähle eine Haltestelle..." Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15" TextWrapping="Wrap"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Objekt-Typ:" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtType" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Übergeordnete Station:" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtParent" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Rollstuhlgerecht:" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtWheelchair" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Tarifzone:" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtZone" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Ebene / Stockwerk:" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtLevel" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,5,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Fußwege (Pathways):" Foreground="#AAAAAA" FontSize="11"/>
                                        <TextBlock x:Name="TxtPathways" Text="-" Foreground="White" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Offizielle Umsteige-Ziele:" Foreground="#AAAAAA" FontSize="11"/>
                                    <TextBlock x:Name="TxtTransfers" Text="-" Foreground="#00D778" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,5,0,15"/>

                                <TextBlock Text="Linien &amp; Abfahrten" Foreground="#0078D7" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock x:Name="TxtLoadingDepartures" Text="Analysiere Fahrpläne &amp; Taktverkehr..." Foreground="#FFAA00" Visibility="Collapsed" Margin="0,0,0,10"/>

                                <ItemsControl x:Name="ListDepartures">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Background="#252526" Foreground="White" BorderBrush="#333" BorderThickness="1" Margin="0,0,0,8" Padding="5">
                                                <Expander.Header>
                                                    <Grid Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Background="{Binding BgBrush}" CornerRadius="4" Padding="8,4" MinWidth="45" Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding LineName}" Foreground="{Binding TextBrush}" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <TextBlock Text="{Binding RouteName}" Foreground="White" FontSize="13" TextTrimming="CharacterEllipsis" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding TotalDeparturesLabel}" Foreground="#00D778" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Expander.Header>

                                                <Border Background="#181818" CornerRadius="4" Padding="15" Margin="5,0,5,5" BorderBrush="#333" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Exakte Abfahrten pro Wochentag:" Foreground="#AAAAAA" FontSize="11" Margin="0,0,0,8"/>
                                                        <TextBlock Text="{Binding DeparturesPerDayString}" Foreground="White" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <TextBlock Text="{Binding AgencyName, StringFormat='Betreiber: {0}'}" Foreground="#888" FontSize="11" Margin="0,10,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <gmap:GMapControl x:Name="MainMap" Zoom="10" MinZoom="2" MaxZoom="18" MouseWheelZoomType="MousePositionAndCenter" Margin="0,1,0,0"/>
                <Border VerticalAlignment="Top" HorizontalAlignment="Right" Background="#CC181818" CornerRadius="8" Padding="15,10" Margin="15" BorderBrush="#333" BorderThickness="1">
                    <TextBlock x:Name="TxtMapInfo" Text="Lade Haltestellen..." Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>