<Window x:Class="GTFSData.FahrplanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="logon.ico"
        Title="Modul: Fahrplan &amp; Abfahrten" Height="850" Width="1450" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded" Background="#121212">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#121212" CornerRadius="4">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#555" CornerRadius="4" Margin="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="TitleBarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#333333"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="CloseButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" x:Key="SmoothTextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0078D7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGrid" x:Key="DarkDataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#181818"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2A2A"/>
            <Setter Property="VerticalGridLinesBrush" Value="#333"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#181818" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <TextBlock Text="GTFS Viewer Pro - Fahrplan Tool" Foreground="#888" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="—" Style="{StaticResource TitleBarButton}" Click="BtnMinimize_Click"/>
                <Button Content="☐" Style="{StaticResource TitleBarButton}" Click="BtnMaximize_Click"/>
                <Button Content="✕" Style="{StaticResource CloseButton}" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <TabControl Background="Transparent" BorderThickness="0" Margin="10" Foreground="White">

                <TabItem Header="📅 LINIEN-FAHRPLAN" FontWeight="Bold" FontSize="14">
                    <Grid Background="#121212" Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                            <WrapPanel VerticalAlignment="Center">
                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="1. Linie:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CboLines" Width="140" Height="30" IsEditable="True" IsTextSearchEnabled="True" KeyUp="CboLines_KeyUp" SelectionChanged="CboLines_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="2. Ansicht &amp; Extras:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <StackPanel Orientation="Horizontal" Height="30" VerticalAlignment="Center">
                                        <CheckBox x:Name="ChkKombiFahrplan" Content="Kombifahrplan" Foreground="#00D778" FontWeight="Bold" VerticalAlignment="Center" Checked="UI_OptionsChanged" Unchecked="UI_OptionsChanged" Margin="0,0,15,0"/>
                                        <CheckBox x:Name="ChkShowDetails" Content="Hinweise (Verkehrstage, Zugnr.)" Foreground="#FFAA00" FontWeight="Bold" VerticalAlignment="Center" Checked="UI_OptionsChanged" Unchecked="UI_OptionsChanged"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="3. Richtung (Wenn nicht gebündelt):" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CboDirection" Width="200" Height="30" SelectionChanged="CboDirection_SelectionChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,20,0">
                                    <TextBlock Text="4. Datum:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <DatePicker x:Name="DpDate" Width="120" Height="30" SelectedDateChanged="DpDate_SelectedDateChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,15,0">
                                    <TextBlock Text="Aktion:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <Button Content="🔄 Berechnen" Background="#0078D7" Foreground="White" FontWeight="Bold" Padding="15,0" Height="30" Click="BtnGenerateMatrix_Click"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Text="Export:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <Button x:Name="BtnExportPdf" Content="📄 PDF Export" Background="#E81123" Foreground="White" FontWeight="Bold" Padding="15,0" Height="30" Click="BtnExportPdf_Click"/>
                                </StackPanel>
                            </WrapPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TimetableItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,30">
                                            <Border Background="#252526" CornerRadius="4" Padding="10,5" Margin="0,0,0,10" BorderBrush="#444" BorderThickness="1">
                                                <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="#00D778"/>
                                            </Border>
                                            <DataGrid ItemsSource="{Binding TableView}" Style="{StaticResource DarkDataGrid}" AutoGenerateColumns="True" IsReadOnly="True" CanUserSortColumns="False" FrozenColumnCount="1"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="⏱️ HALTESTELLEN-MONITOR" FontWeight="Bold" FontSize="14">
                    <Grid Background="#121212" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="350"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,15,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="1. Haltestelle suchen:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="TxtStopSearch" Style="{StaticResource SmoothTextBox}" Height="30" TextChanged="TxtStopSearch_TextChanged" Margin="0,0,0,10"/>
                                    <ListBox x:Name="ListStops" Height="200" Background="#1E1E1E" Foreground="White" BorderBrush="#333" SelectionChanged="ListStops_SelectionChanged" Margin="0,0,0,20"/>

                                    <TextBlock Text="2. Zeitraum:" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePicker x:Name="DpStopDate" Grid.Column="0" Height="30" Margin="0,0,5,0"/>
                                        <TextBox x:Name="TxtStopTime" Grid.Column="1" Style="{StaticResource SmoothTextBox}" Text="08:00" Height="30" Margin="5,0,0,0" ToolTip="Ab Uhrzeit (HH:mm)"/>
                                    </Grid>
                                    <CheckBox x:Name="ChkWholeDay" Content="Ganzen Tag zeigen (Limit aus)" Foreground="White" Margin="0,0,0,20" IsChecked="True"/>

                                    <TextBlock Text="3. Filter (Optional):" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CboFilterLine" IsEditable="True" Height="30" Margin="0,0,0,10" ToolTip="Nur bestimmte Linie anzeigen"/>
                                    <TextBox x:Name="TxtFilterDest" Style="{StaticResource SmoothTextBox}" Height="30" Margin="0,0,0,20" ToolTip="Ziel eingeben (z.B. Bahnhof)"/>

                                    <Button Content="Abfahrten laden 🚀" Background="#0078D7" Foreground="White" FontWeight="Bold" Height="40" Click="BtnShowDepartures_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Column="1" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="15">
                            <ListView x:Name="ListDepartures" Background="Transparent" BorderThickness="0" Foreground="White" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Zeit" Width="100" DisplayMemberBinding="{Binding Time}"/>
                                        <GridViewColumn Header="Linie" Width="100" DisplayMemberBinding="{Binding Line}"/>
                                        <GridViewColumn Header="Richtung / Ziel" Width="500" DisplayMemberBinding="{Binding Destination}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>