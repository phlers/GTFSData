<Window x:Class="GTFSData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="logon.ico"
        Title="GTFS Viewer Pro 2026" Height="680" Width="1000" WindowStartupLocation="CenterScreen" Background="#121212">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ModernTile">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="220"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#252525"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#181818" Padding="20,15" BorderBrush="#222" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="TxtGtfsStatus" Text="System wird initialisiert..." Foreground="#0078D7" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtGtfsDetails" Text="Prüfe gespeicherte Daten..." Foreground="#888" FontSize="12" Margin="0,3,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="📁 Neuen Datensatz laden" Click="BtnLoadGtfs_Click" Padding="15,8" Background="#0078D7" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,40,0,40">
                <TextBlock Text="GTFS CONTROL CENTER" HorizontalAlignment="Center" Foreground="#444" FontWeight="Black" FontSize="12" Margin="0,10,0,0"/>

                <WrapPanel HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Style="{StaticResource ModernTile}" Click="TileGtfsToShp_Click">
                        <StackPanel>
                            <TextBlock Text="🗺️" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="GTFS TO SHAPE" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="GIS Export &amp; Linienwege" Foreground="#666" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModernTile}" Click="TileHaltestellen_Click">
                        <StackPanel>
                            <TextBlock Text="🚏" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="STOP VIEWER" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Haltestellen &amp; Details" Foreground="#666" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModernTile}" Click="TileAccessibility_Click">
                        <StackPanel>
                            <TextBlock Text="📏" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="ACCESSIBILITY" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Radien &amp; Einzugsbereiche" Foreground="#666" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ModernTile}" Click="TileFahrplan_Click">
                        <StackPanel>
                            <TextBlock Text="📅" FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="FAHRPLAN TOOL" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Tabellen &amp; Live-Abfahrten" Foreground="#666" FontSize="11" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </ScrollViewer>

        <ProgressBar x:Name="ProgBar" Grid.Row="2" Height="4" Foreground="#0078D7" Background="Transparent" BorderThickness="0" Visibility="Collapsed"/>
    </Grid>
</Window>